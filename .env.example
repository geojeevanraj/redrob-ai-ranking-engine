# ─────────────────────────────────────────────────────────────
# AI Recruitment Intelligence Platform — Environment Template
# Copy to `.env` and adjust. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# App environment: development | testing | production
APP_ENV=development

# ── Backend ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
LOG_JSON=false

# ── Document Upload / Storage ────────────────────────────────
DOCUMENT_STORAGE_DIR=./var/uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_DOCUMENT_EXTENSIONS=pdf,docx,txt

# ── Database (PostgreSQL + pgvector) ─────────────────────────
POSTGRES_USER=recruit
POSTGRES_PASSWORD=recruit_dev_pw
POSTGRES_DB=recruitment
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async SQLAlchemy URL is derived from the parts above by settings.py;
# override here only if you need a custom DSN.
# DATABASE_URL=postgresql+asyncpg://recruit:recruit_dev_pw@localhost:5432/recruitment

# ── AI / LLM Infrastructure ──────────────────────────────────
# Provider selection (Strategy pattern). Values: gemini | ollama | mock
PRIMARY_LLM_PROVIDER=gemini
FALLBACK_LLM_PROVIDER=ollama

# Manager-level behavior
LLM_TIMEOUT=30
LLM_MAX_RETRIES=1

# Gemini (primary)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.0
GEMINI_MAX_TOKENS=8192
GEMINI_TIMEOUT=30

# Ollama (fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT=60

# Embeddings (future sprints)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Offline Candidate Ranking (Sprint 9.1) ───────────────────
# Path to the official Redrob candidates JSONL dataset (streamed, not loaded
# wholesale). Optional: can also be supplied per-request as `dataset_path`.
RANKING_DATASET_PATH=
# Directory where exported top-N ranking CSVs are written.
RANKING_EXPORT_DIR=./var/rankings
