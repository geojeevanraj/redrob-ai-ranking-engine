# ─────────────────────────────────────────────────────────────
# Production environment template — copy to `.env` for local prod runs,
# or set these as platform environment variables (Render/Railway dashboard).
# NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

APP_ENV=production
LOG_JSON=true

# ── Database ─────────────────────────────────────────────────
# The backend assembles an asyncpg DSN from these parts. On Render these are
# injected automatically from the managed database (see render.yaml).
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=recruit
POSTGRES_PASSWORD=change_me
POSTGRES_DB=recruitment
# Optional explicit DSN override (must use the +asyncpg driver):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/recruitment

# ── LLM (Gemini used ONLY for job-description parsing) ───────
PRIMARY_LLM_PROVIDER=gemini
FALLBACK_LLM_PROVIDER=ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Demo dataset (small sample bundled in the image) ─────────
RANKING_DATASET_PATH=/app/dataset/sample_candidates.jsonl
RANKING_EXPORT_DIR=/app/backend/var/rankings

# ── Sandbox → backend wiring (same container) ────────────────
SANDBOX_BACKEND_URL=http://localhost:8000/api/v1
SANDBOX_OFFICIAL_DATASET=/app/dataset/sample_candidates.jsonl
SANDBOX_OFFICIAL_JD=/app/dataset/job_description.docx
